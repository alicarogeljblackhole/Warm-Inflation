Cell[BoxData[
 RowBox[{
  RowBox[{"Hlate", "[", "Te_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Sqrt", "[", 
    RowBox[{"8", 
     RowBox[{"\[Pi]", "/", "3"}]}], "]"}], 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     RowBox[{"er", "[", "Te", "]"}], "]"}], "/", "mpl"}]}]}]], "Input",
 CellChangeTimes->{{3.960263156222189*^9, 3.960263205150383*^9}, {
