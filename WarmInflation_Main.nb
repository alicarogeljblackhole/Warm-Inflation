Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Quiet", "[", 
    RowBox[{
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"kal", "[", "t", "]"}], ",", "t"}], "]"}], "==", 
