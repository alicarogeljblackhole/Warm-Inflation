Cell[BoxData[
 RowBox[{
  RowBox[{"Quiet", "[", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"count", "=", "0"}], "}"}], ",", 
     RowBox[{"bckfull", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"BackgroundEquation1", "[", "t", "]"}], ",", 
          RowBox[{"BackgroundEquation2", "[", "t", "]"}], ",", 
          "initialconditionsT\[Phi]", ",", 
          RowBox[{"WhenEvent", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"1", "/", "2"}], " ", 
                 SuperscriptBox[
                  RowBox[{
                   SuperscriptBox["\[Phi]", "\[Prime]",
                    MultilineFunction->None], "[", "t", "]"}], "2"]}], "+", 
                RowBox[{"V", "[", 
                 RowBox[{
                  RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
                  RowBox[{"Te", "[", "t", "]"}]}], "]"}], "-", 
                RowBox[{
                 RowBox[{"Te", "[", "t", "]"}], 
                 RowBox[{
                  SuperscriptBox["V", 
                   TagBox[
                    RowBox[{"(", 
                    RowBox[{"0", ",", "1"}], ")"}],
                    Derivative],
                   MultilineFunction->None], "[", 
                  RowBox[{
                   RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
                   RowBox[{"Te", "[", "t", "]"}]}], "]"}]}]}], ")"}], "/", 
              RowBox[{"er", "[", 
               RowBox[{"Te", "[", "t", "]"}], "]"}]}], "<=", "1000"}], 
            ",", "\"\<StopIntegration\>\""}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Phi]", ",", "Te"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "1", ",", 
          RowBox[{"10", "^", "20"}]}], "}"}], ",", 
        RowBox[{"AccuracyGoal", "->", "50"}], ",", 
        RowBox[{"PrecisionGoal", "->", "10"}], ",", 
        RowBox[{"MaxSteps", "->", 
         RowBox[{"10", "^", "9"}]}], ",", 
        RowBox[{"WorkingPrecision", "->", "50"}]}], "]"}]}]}], "]"}], "]"}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.955528050761469*^9, 3.955528050762416*^9}, {
   3.95553122293468*^9, 3.955531242653208*^9}, {3.955531282495829*^9, 
