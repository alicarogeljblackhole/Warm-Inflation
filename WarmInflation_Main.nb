Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "create", " ", "time", " ", "points", " ", "for", " ", "graph", " ", 
     "plotting"}], ",", " ", 
    RowBox[{"logarithmically", " ", "spaced"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"timesLog", "=", 
     RowBox[{"Log", "[", "times", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"logMinn", "=", 
     RowBox[{"First", "[", "timesLog", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"logMaxn", "=", 
     RowBox[{"Last", "[", "timesLog", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"edges", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"logMinn", ",", "logMaxn", ",", "nPoints"}], "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"log", "-", 
     RowBox[{"chosen", " ", "time", " ", "point", " ", "to", " ", "plot"}]}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"'", 
       RowBox[{"edges", "'"}], " ", "need", " ", "not", " ", "coincide", " ", 
       RowBox[{"with", " ", "'"}], 
       RowBox[{"times", "'"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"find", " ", "'"}], 
       RowBox[{"times", "'"}], " ", "points", " ", 
       RowBox[{"at", "/", "just"}], " ", "after", " ", "the", " ", 
       RowBox[{"suggested", " ", "'"}], 
       RowBox[{"edges", "'"}], " ", "time", " ", "values"}]}], " ", "=", " ", 
     "inds"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"inds", "=", 
     RowBox[{
      RowBox[{"Reap", "[", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", "=", "1"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"While", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"i", "<", 
                RowBox[{"Length", "[", "timesLog", "]"}]}], "&&", 
               RowBox[{
                RowBox[{"timesLog", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "<", "edge"}]}], ",", 
              RowBox[{"i", "++"}]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"i", "<=", 
               RowBox[{"Length", "[", "timesLog", "]"}]}], ",", 
              RowBox[{"Sow", "[", "i", "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"edge", ",", "edges"}], "}"}]}], "]"}]}], "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"inds", "=", 
     RowBox[{"DeleteDuplicates", "[", "inds", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "compute", " ", "background", " ", "at", " ", "inds", " ", "needed", " ", 
     "to", " ", "plot", " ", "curvature", " ", "instead", " ", "of", " ", 
     "isocurvature", " ", 
     RowBox[{"pert", "."}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"denvArray", "=", 
     RowBox[{
      RowBox[{"eav", "[", 
       RowBox[{"\[Phi]s", ",", "Ts"}], "]"}], "+", 
      RowBox[{"pav", "[", 
       RowBox[{"\[Phi]s", ",", "Ts"}], "]"}]}]}], ";"}], "  ", "\n", 
   RowBox[{
    RowBox[{"denTArray", "=", 
     RowBox[{"ederTs", "*", 
      RowBox[{"Tdots", "/", "tref"}]}]}], ";"}], "            ", "\n", 
   RowBox[{
    RowBox[{"denvSample", "=", 
     RowBox[{"denvArray", "[", 
      RowBox[{"[", "inds", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"denTSample", "=", 
     RowBox[{"denTArray", "[", 
      RowBox[{"[", "inds", "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.959162488091631*^9, 3.959162498424444*^9}, {
