Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "will", " ", "be", " ", "optimized", " ", "for", " ", "potentials", " ", 
    "inducing", " ", "early", " ", "matter", " ", "domination"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"count", "=", "0"}], "}"}], ",", 
     RowBox[{"bckfull2", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"er", "[", 
                RowBox[{"Te", "[", "t", "]"}], "]"}], ",", "t"}], "]"}], "/", 
             "tref"}], "+", 
            RowBox[{"3", 
             RowBox[{"Hlate", "[", 
              RowBox[{"Te", "[", "t", "]"}], "]"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"er", "[", 
                RowBox[{"Te", "[", "t", "]"}], "]"}], "+", 
               RowBox[{"pr", "[", 
                RowBox[{"Te", "[", "t", "]"}], "]"}]}], ")"}]}]}], "==", 
           "0"}], ",", 
          RowBox[{
           RowBox[{"Te", "[", "ts", "]"}], "==", 
           RowBox[{"Tbck1", "[", "ts", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"WhenEvent", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Te", "[", "t", "]"}], "==", 
             RowBox[{"10", "^", 
              RowBox[{"-", "12"}]}]}], ",", "\"\<StopIntegration\>\""}], 
           "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Phi]", ",", "Te", ",", "ka"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "ts", ",", 
          RowBox[{"10", "^", "30"}]}], "}"}], ",", 
        RowBox[{"AccuracyGoal", "->", "50"}], ",", 
        RowBox[{"PrecisionGoal", "->", "10"}], ",", 
        RowBox[{"MaxSteps", "->", 
         RowBox[{"10", "^", "9"}]}], ",", 
        RowBox[{"WorkingPrecision", "->", "50"}]}], "]"}]}]}], "]"}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.960262719191185*^9, 3.960262722634554*^9}, {
