Cell[TextData[{
 "Find time at which to start (ti) and end (tf) the perturbative evolution, \
as well as the time of the horizon crossing (tmatch).\n",
 StyleBox["The  cells below first tries to find approximate times, and then \
finds the exact values. That is because FindRoot is very slow if we do not \
provide a narrow interval in which the root is suppose to lie.",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.952508062355854*^9, 3.952508145089174*^9}, {
  3.952508175473284*^9, 3.952508330477824*^9}, {3.9558017730561113`*^9, 
  3.955801825911108*^9}, {3.9558021812964473`*^9, 3.955802270918602*^9}, {
  3.987160751825152*^9, 3.9871607792795258`*^9}, {3.987160840198819*^9, 
  3.987160865942279*^9}, {3.98716094171692*^9, 3.987161029987656*^9}, {
  3.987161135584799*^9, 3.987161202583857*^9}, {3.9871622237725897`*^9, 
  3.987162365137495*^9}, {3.987163946235766*^9, 
  3.987163948395775*^9}},ExpressionUUID->"b107f2d5-b1b1-4886-ac57-\
75c6d1ad8364"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"finds", " ", "an", " ", "interval", " ", "in", " ", "which", " ", 
     RowBox[{"a", " ", "'"}], 
     RowBox[{"function", "'"}], " ", 
     RowBox[{"(", 
      RowBox[{"such", " ", "as", " ", 
       RowBox[{"k", "/", 
        RowBox[{"(", 
         RowBox[{"a", " ", "H"}], ")"}]}]}], ")"}], "  ", "obtains", " ", 
     RowBox[{"its", " ", "'"}], 
