Cell[BoxData[
 RowBox[{
  RowBox[{"\[Epsilon]ks", "=", 
   RowBox[{"Re", "[", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"kas", "^", "2"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[CapitalUpsilon]s", "+", "Fs", "+", 
         RowBox[{"2", "Hs"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"Fs", "+", "Hs"}], ")"}]}], "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Hdots", "/", "tref"}], "+", 
        RowBox[{"Fdots", "/", "tref"}]}], ")"}]}], "]"}], "]"}]}], 
  ";"}]], "Input",
