Cell[BoxData[
 RowBox[{
  RowBox[{"\[CurlyEpsilon]", "[", 
   RowBox[{"t_", ",", "n_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"10", "^", 
    RowBox[{"(", 
     RowBox[{"-", "n"}], ")"}]}], "/", 
   RowBox[{"Max", "[", 
    RowBox[{"Abs", "/@", 
     RowBox[{"Eigenvalues", "[", 
      RowBox[{"Matr", "[", "t", "]"}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.987218957083619*^9, 3.987218969483069*^9}},
 CellLabel->
  "In[112]:=",ExpressionUUID->"d20adb67-b1af-4fb1-ba3f-f4a326861ba9"],

Cell[TextData[{
 "Directly evaluating \[CurlyEpsilon] is numerically expensive.\nFind the \
sizes of time steps in intervals of \[OpenCurlyQuote]",
 StyleBox["interp\[CloseCurlyQuote]",
  IgnoreSpellCheck->True],
 " , then interpolate the result. Use Log as the step sizes are very small at \
first; it additionally ensures \[CurlyEpsilon] is interpolated to positive \
values."
}], "Text",
 CellChangeTimes->{{3.9872205509120626`*^9, 3.9872205656451263`*^9}, {
  3.987220651815565*^9, 3.987220767824794*^9}, {3.9872207993203993`*^9, 
  3.98722093590974*^9}, {3.987220986692049*^9, 3.987221010098277*^9}, {
  3.987221083978717*^9, 3.987221095594338*^9}, {3.987221369445661*^9, 
  3.9872213698451242`*^9}},ExpressionUUID->"233fdd7a-c9a8-44f6-85b8-\
ea0aa0772ce5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Quiet", "[", 
   RowBox[{
    RowBox[{"Interpolation", "[", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Log", "[", 
          RowBox[{"\[CurlyEpsilon]", "[", 
           RowBox[{"i", ",", "n"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "ti", ",", 
         RowBox[{"tf", "+", "interp", "+", "5"}], ",", "interp"}], "}"}]}], 
      "]"}], "\[IndentingNewLine]", "]"}], "[", "t", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CurlyEpsilon]approx1", "[", "t_", "]"}], ":=", 
  RowBox[{"Evaluate", "[", "%", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CurlyEpsilon]approx", "[", "t_", "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{"\[CurlyEpsilon]approx1", "[", "t", "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.958033058443267*^9, 3.958033074330912*^9}, {
