Cell[BoxData[
 RowBox[{
  RowBox[{"H", "[", 
   RowBox[{"\[Phi]_", ",", "Te_", ",", "depvar_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "mpl"], "2", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{"2", " ", "\[Pi]"}], "3"]], " ", 
   RowBox[{"\[Sqrt]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"er", "[", "Te", "]"}], "+", 
      RowBox[{"V", "[", 
       RowBox[{"\[Phi]", ",", "Te"}], "]"}], "+", 
      RowBox[{
       FractionBox["1", "2"], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"\[Phi]", ",", "depvar"}], "]"}], "^", "2"}], "/", 
        RowBox[{"tref", "^", "2"}]}]}], "-", 
      RowBox[{"Te", " ", 
       RowBox[{
        SuperscriptBox["V", 
         TagBox[
          RowBox[{"(", 
           RowBox[{"0", ",", "1"}], ")"}],
          Derivative],
         MultilineFunction->None], "[", 
        RowBox[{"\[Phi]", ",", "Te"}], "]"}]}]}], ")"}]}]}]}]], "Input",
 CellChangeTimes->{{3.990241407892515*^9, 3.990241413978681*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"1a93416b-8698-4eac-a6b0-6c1c6774542a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BackgroundEquation1", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "t", "]"}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"3", 
          RowBox[{"H", "[", 
           RowBox[{
            RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
            RowBox[{"Te", "[", "t", "]"}], ",", "t"}], "]"}]}], "+", 
         RowBox[{"\[CapitalUpsilon]", "[", 
          RowBox[{
           RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
           RowBox[{"Te", "[", "t", "]"}], ",", "t"}], "]"}]}], ")"}]}], 
      RowBox[{
       SuperscriptBox["\[Phi]", "\[Prime]",
        MultilineFunction->None], "[", "t", "]"}], "tref"}], "-", 
     RowBox[{
      RowBox[{"tref", "^", "2"}], " ", 
      RowBox[{
       SuperscriptBox["V", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"1", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{
        RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
        RowBox[{"Te", "[", "t", "]"}]}], "]"}]}]}]}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BackgroundEquation2", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"er", "[", 
       RowBox[{"Te", "[", "t", "]"}], "]"}], ",", "t"}], "]"}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "3"}], 
      RowBox[{"H", "[", 
       RowBox[{
        RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
        RowBox[{"Te", "[", "t", "]"}], ",", "t"}], "]"}], "tref", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"er", "[", 
         RowBox[{"Te", "[", "t", "]"}], "]"}], "+", 
        RowBox[{"pr", "[", 
         RowBox[{"Te", "[", "t", "]"}], "]"}], "-", 
        RowBox[{
         RowBox[{"Te", "[", "t", "]"}], 
         RowBox[{"D", "[", " ", 
          RowBox[{
           RowBox[{"V", "[", 
            RowBox[{
             RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
             RowBox[{"Te", "[", "t", "]"}]}], "]"}], ",", 
           RowBox[{"Te", "[", "t", "]"}]}], "]"}]}]}], ")"}]}], "+", 
     RowBox[{
      RowBox[{"Te", "[", "t", "]"}], 
      RowBox[{"D", "[", " ", 
       RowBox[{
        RowBox[{"V", "[", 
         RowBox[{
          RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
          RowBox[{"Te", "[", "t", "]"}]}], "]"}], ",", 
        RowBox[{"Te", "[", "t", "]"}], ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"\[CapitalUpsilon]", "[", 
       RowBox[{
        RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
        RowBox[{"Te", "[", "t", "]"}], ",", "t"}], "]"}], 
      RowBox[{
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["\[Phi]", "\[Prime]",
          MultilineFunction->None], "[", "t", "]"}], "2"], "/", 
       "tref"}]}]}]}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"initialconditionsT\[Phi]", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Phi]", "[", "1", "]"}], "==", "\[Phi]ref"}], ",", 
     RowBox[{
      RowBox[{"Te", "[", "1", "]"}], "==", "Tref"}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Phi]", "\[Prime]",
        MultilineFunction->None], "[", "1", "]"}], "==", 
      RowBox[{"\[Phi]dotref", "[", "Tref", "]"}]}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{
  3.951204259838737*^9, 3.951218276977171*^9, {3.95121930080912*^9, 
