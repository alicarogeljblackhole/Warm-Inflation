Cell["find initial temperature", "Text",
 CellChangeTimes->{{3.986874730154492*^9, 3.986874736624442*^9}},
 Background->None,ExpressionUUID->"7cf291c4-0c95-479e-8593-a9f0560a4f92"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Quiet", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"SafeTrefSolve", "[", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"internally", " ", "define", " ", "variables"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "T0", ",", "sols", ",", "filteredSols", ",", "relImag", ",", 
         "bestSol"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"solve", " ", "for", " ", "initial", " ", "temperature"}], ";",
           " ", 
          RowBox[{
           RowBox[{"eq", ".", " ", 
            RowBox[{"(", "9.7", ")"}]}], " ", 
           RowBox[{"from", " ", "[", "1", "]"}]}]}], "]"}], "*)"}], 
       RowBox[{
        RowBox[{"T0", "=", 
         RowBox[{"Quiet", "@", 
          RowBox[{"NSolve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"3", " ", "Href", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"pr", "[", "Tref", "]"}], "+", 
                RowBox[{"er", "[", "Tref", "]"}]}], ")"}]}], "==", 
             RowBox[{
              RowBox[{
               RowBox[{"\[Phi]dotref", "[", "Tref", "]"}], "^", "2"}], " ", 
              RowBox[{"\[CapitalUpsilon]ref", "[", "Tref", "]"}]}]}], ",", 
            "Tref"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "write", " ", "solutions", " ", "as", " ", "a", " ", "list"}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"sols", "=", 
         RowBox[{"Replace", "[", 
          RowBox[{
           RowBox[{"Tref", "/.", " ", "T0"}], ",", 
           RowBox[{
            RowBox[{"x_", "/;", 
             RowBox[{"AtomQ", "[", "x", "]"}]}], ":>", 
            RowBox[{"{", "x", "}"}]}]}], "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"solution", " ", "is", " ", "T"}], ";", " ", 
          RowBox[{
          "we", " ", "expect", " ", "this", " ", "to", " ", "be", " ", "a", " ",
            "numerical", " ", "value", " ", "with", " ", "real", " ", "part", 
           " ", "between", " ", "0", " ", "and", " ", "1", " ", "Planck", " ",
            "mass"}]}], "*)"}], 
        RowBox[{"filteredSols", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"sols", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"NumericQ", "[", "#", "]"}], "&&", 
             RowBox[{"0", "<", 
              RowBox[{"Re", "[", "#", "]"}], "<", "1"}]}], "&"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "check", " ", "if", " ", "multiple", " ", "solutions", " ", "fit", " ",
           "this", " ", "criteria"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "filteredSols", "]"}], ">", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"if", " ", 
             RowBox[{"yes", ":", " ", 
              RowBox[{
              "pick", " ", "the", " ", "most", " ", "sensible", " ", 
               "solution"}]}]}], " ", "=", " ", 
            RowBox[{"fully", " ", 
             RowBox[{"real", "/", "least"}], " ", "imaginary", " ", "one"}]}],
            "*)"}], 
          RowBox[{
           RowBox[{"relImag", "=", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"Im", "[", "#", "]"}], "]"}], "/", 
               RowBox[{"Abs", "[", 
                RowBox[{"Re", "[", "#", "]"}], "]"}]}], "&"}], "/@", 
             "filteredSols"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"bestSol", "=", 
            RowBox[{"filteredSols", "[", 
             RowBox[{"[", 
              RowBox[{"First", "@", 
               RowBox[{"Ordering", "[", 
                RowBox[{"relImag", ",", "1"}], "]"}]}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
            "take", " ", "its", " ", "real", " ", "part", " ", "as", " ", 
             "your", " ", "initial", " ", "temperature", " ", "guess"}], 
            "*)"}], "\[IndentingNewLine]", 
           RowBox[{"Re", "[", "bestSol", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"if", " ", 
             RowBox[{"no", ":", " ", 
              RowBox[{"default", " ", "to", " ", 
               RowBox[{"10", "^", 
                RowBox[{"-", "5"}]}]}]}]}], ",", " ", 
            RowBox[{
            "which", " ", "is", " ", "usually", " ", "an", " ", "acceptable", 
             " ", "starting", " ", "point"}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
           "Print", "[", "\"\<[Warning] Tref defaulted to 10^-5\>\"", "]"}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"10", "^", 
            RowBox[{"-", "5"}]}]}]}], "]"}]}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"Select", "::", "normal"}], "}"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tref", "=", 
   RowBox[{"SafeTrefSolve", "[", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.959247706800419*^9, 3.9592477068012037`*^9}, {
   3.959336987178355*^9, 3.959336989729828*^9}, {3.959341106232563*^9, 
