Cell[CellGroupData[{

Cell[TextData[{
 "tabulate momentum, noise ",
 StyleBox["autocorrelator",
  IgnoreSpellCheck->True],
 ", form matrix elements"
}], "Subsubsection",
 CellChangeTimes->{{3.98722534349339*^9, 
  3.987225403783875*^9}},ExpressionUUID->"4e7724c2-55a5-45ac-ae94-\
646efb65a597"],

Cell["\<\
In order to compute the spectral tilt, power spectra need to be computed also \
for a slightly larger and slightly smaller k/a. We evaluate all quantities \
which are sensitive to k/a three times (the additional two evaluations are \
always in blue boxes; higher momentum evaluations end with p, lower with m).\
\>", "Text",
 CellChangeTimes->{{3.98723649181564*^9, 3.987236542770891*^9}, {
  3.987236577281973*^9, 3.987236644824478*^9}, {3.987236843813242*^9, 
  3.987236877036821*^9}},ExpressionUUID->"28413ea5-bca8-4f43-9b2d-\
4910996ac3a0"],

Cell["k/a and the noise", "Text",
 CellChangeTimes->{{3.987237671745234*^9, 
  3.987237680669504*^9}},ExpressionUUID->"7632e42d-a9e6-4420-ad0c-\
5733069997f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"kas", "=", 
    RowBox[{"kabck", "/@", "times"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"k", "/", "a"}], " ", "list"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.987236372646607*^9, 3.987236380517832*^9}},
 CellLabel->
  "In[146]:=",ExpressionUUID->"6a14ec8e-721e-41c5-b11c-5ce7ee65303a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"kasp", "=", 
   RowBox[{
    RowBox[{"10", "^", 
     RowBox[{"(", "tilt", ")"}]}], " ", 
    RowBox[{"kabck", "/@", "times"}]}]}], 
  RowBox[{"(*", 
   RowBox[{"slightly", " ", "larger", " ", 
    RowBox[{"k", "/", "a"}]}], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kasm", "=", 
   RowBox[{
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "tilt"}], ")"}]}], " ", 
    RowBox[{"kabck", "/@", "times"}]}]}], 
  RowBox[{"(*", 
   RowBox[{"slightly", " ", "smaller", " ", 
    RowBox[{"k", "/", "a"}]}], "*)"}], ";"}]}], "Input",
 CellChangeTimes->{{3.959927770576452*^9, 3.9599278231999817`*^9}, {
