Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"standard", " ", "thermodynamics"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eav", "[", 
     RowBox[{"\[Phi]_", ",", "Te_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"er", "[", "Te", "]"}], "+", 
     RowBox[{"V", "[", 
      RowBox[{"\[Phi]", ",", "Te"}], "]"}], "-", 
     RowBox[{"Te", " ", 
      RowBox[{
       SuperscriptBox["V", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "1"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"\[Phi]", ",", "Te"}], "]"}]}]}]}], 
   RowBox[{"(*", 
    RowBox[{"average", " ", "energy", " ", "density"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pav", "[", 
     RowBox[{"\[Phi]_", ",", "Te_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"pr", "[", "Te", "]"}], "-", 
     RowBox[{"V", "[", 
      RowBox[{"\[Phi]", ",", "Te"}], "]"}], 
     RowBox[{"(*", 
      RowBox[{"average", " ", "pressure"}], "*)"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.9887103012249527`*^9, 3.988710312032578*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"e925bdd4-07b5-4325-9e86-dd359dc13dd4"],

Cell["derive initial values at reference time", "Text",
 CellChangeTimes->{{3.987143985779441*^9, 3.987144000208219*^9}, {
  3.9871491620369368`*^9, 
  3.987149166245185*^9}},ExpressionUUID->"b4d5730a-6104-47c3-a77a-\
e3d50aa1721c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "Tref", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tref", "=", 
   RowBox[{"SetPrecision", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", 
       FractionBox["3", 
        RowBox[{"8", "\[Pi]", " ", 
         RowBox[{"V", "[", 
          RowBox[{"\[Phi]ref", ",", "Tref"}], "]"}]}]], "]"}], "mpl"}], ",", 
     "50"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Href", "=", 
    RowBox[{"1", "/", "tref"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"H", " ", "at", " ", "ref", " ", "time"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalUpsilon]ref", "[", "Tref_", "]"}], ":=", 
   RowBox[{
    RowBox[{"\[CapitalUpsilon]", "[", 
     RowBox[{"\[Phi]", ",", "Te", ",", "depvar"}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Te", "->", "Tref"}], ",", 
      RowBox[{"\[Phi]", "->", "\[Phi]ref"}], ",", 
      RowBox[{
       RowBox[{"H", "[", 
        RowBox[{"\[Phi]", ",", "Te", ",", "depvar"}], "]"}], "->", "Href"}]}],
      "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]dotref", "[", "Tref_", "]"}], ":=", 
   RowBox[{
    RowBox[{"-", " ", 
     RowBox[{
      SuperscriptBox["V", 
       TagBox[
        RowBox[{"(", 
         RowBox[{"1", ",", "0"}], ")"}],
        Derivative],
       MultilineFunction->None], "[", 
      RowBox[{"\[Phi]ref", ",", "Tref"}], "]"}]}], 
    RowBox[{"tref", "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", "Href"}], " ", "+", 
       RowBox[{"\[CapitalUpsilon]ref", "[", "Tref", "]"}]}], ")"}]}]}]}], 
  ";"}]}], "Input",
