Cell[BoxData[
 RowBox[{
  RowBox[{"table", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<Log10[\[Lambda]]\>\"", ",", "\"\<fa [10^12 GeV]\>\"", 
       ",", "\"\<\[Alpha]s\>\"", ",", 
       RowBox[{"\"\<t_init \>\"", "whentostart", "\"\<=k/aH,\>\""}], 
       ",", "\"\<\[Phi][t_init]/mpl\>\"", ",", "\"\<T/H exit\>\"", 
       ",", "\"\<\[CapitalUpsilon]/3H exit\>\"", 
       ",", "\"\<|\[Phi]dot|/H^2 exit\>\"", ",", "\"\<\[Phi]dot exit\>\"", 
       ",", "\"\<\[Phi] exit\>\"", ",", "\"\<H exit\>\"", 
       ",", "\"\<A=R\[Phi]_(k/aH)=10^5\>\"", ",", "\"\<n_s(pivot*)\>\"", 
       ",", "\"\<r\>\"", ",", "\"\<Rv_(k/aH)=10^5\>\"", 
       ",", "\"\<n_sv(pivot*)\>\"", ",", "\"\<rv\>\"", 
       ",", "\"\<RT_(k/aH)=10^5\>\"", ",", "\"\<n_sT(pivot*)\>\"", 
       ",", "\"\<rT\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{"10", ",", "\[Lambda]"}], "]"}], ",", 
       RowBox[{"falist", "[", 
        RowBox[{"[", "j", "]"}], "]"}], ",", "\[Alpha]", ",", "ti", ",", 
       RowBox[{"\[Phi]bck", "[", "ti", "]"}], ",", 
       RowBox[{
        RowBox[{"Tbck", "[", "tmatch", "]"}], "/", 
        RowBox[{"Hbck", "[", "tmatch", "]"}]}], ",", 
       RowBox[{
        RowBox[{"\[CapitalUpsilon]bck", "[", "tmatch", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"3", 
          RowBox[{"Hbck", "[", "tmatch", "]"}]}], ")"}]}], ",", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"\[Phi]dot", "[", "tmatch", "]"}], "/", "tref"}], "]"}], "/", 
        RowBox[{
         RowBox[{"Hbck", "[", "tmatch", "]"}], "^", "2"}]}], ",", 
       RowBox[{
        RowBox[{"\[Phi]dot", "[", "tmatch", "]"}], "/", "tref"}], ",", 
       RowBox[{"\[Phi]bck", "[", "tmatch", "]"}], ",", 
       RowBox[{"Hbck", "[", "tmatch", "]"}], ",", 
       RowBox[{"PR\[Phi]", "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}], ",", "ns", ",", "r", ",", 
       RowBox[{"PRv", "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}], ",", "nsv", ",", "rv", ",", 
       RowBox[{"PRT", "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}], ",", "nsT", ",", "rT"}], "}"}]}], 
    "}"}]}], ";"}]], "Input",
