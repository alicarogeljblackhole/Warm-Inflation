   RowBox[{
    RowBox[{"N", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Id", "=", 
          RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "}"}], ",", 
