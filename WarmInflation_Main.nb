        RowBox[{"[", 
         RowBox[{"inds", ",", "4", ",", "4"}], "]"}], "]"}], "/", 
       RowBox[{"denTSample", "^", "2"}]}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
