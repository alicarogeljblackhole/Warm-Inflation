Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"find", " ", "solutions"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Quiet", "[", 
   RowBox[{
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Id", "=", 
          RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "}"}], ",", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"SolMatrixp", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Id", "+", 
               RowBox[{
                RowBox[{"dts", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], " ", 
                RowBox[{"Mp", "[", "i", "]"}]}]}], ")"}], ".", 
             RowBox[{"SolMatrixp", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ".", 
             RowBox[{"(", 
              RowBox[{"Id", "+", 
               RowBox[{
                RowBox[{"dts", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], " ", 
                RowBox[{"MTp", "[", "i", "]"}]}]}], ")"}]}], "+", 
            RowBox[{
             RowBox[{"dts", "[", 
              RowBox[{"[", "i", "]"}], "]"}], " ", 
             RowBox[{"Ncoeff", "[", "i", "]"}], " ", 
             RowBox[{"Noisep", "[", "i", "]"}]}]}]}], ",", 
          RowBox[{"{", 
