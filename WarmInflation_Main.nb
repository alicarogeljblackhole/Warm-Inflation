Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Epsilon]ksp", "=", 
   RowBox[{"Re", "[", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"kasp", "^", "2"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[CapitalUpsilon]s", "+", "Fs", "+", 
         RowBox[{"2", "Hs"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"Fs", "+", "Hs"}], ")"}]}], "-", 
