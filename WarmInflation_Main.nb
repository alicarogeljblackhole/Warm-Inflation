Cell[BoxData[
 RowBox[{
  RowBox[{"TimeSteps", "[", 
   RowBox[{"t0_", ",", "tf_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", "=", 
        RowBox[{"SetPrecision", "[", 
         RowBox[{"t0", ",", "50"}], "]"}]}], ",", "dt"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Reap", "[", 
       RowBox[{
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"t", "<=", 
           RowBox[{"tf", "+", 
            RowBox[{"10", "^", 
             RowBox[{"(", 
              RowBox[{"-", "n"}], ")"}]}]}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"dt", "=", 
            RowBox[{"SetPrecision", "[", 
             RowBox[{
              RowBox[{"\[CurlyEpsilon]approx", "[", "t", "]"}], ",", "50"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Sow", "[", 
            RowBox[{"{", 
             RowBox[{"t", ",", "dt"}], "}"}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"t", "+=", "dt"}]}]}], "]"}], ";"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "]"}], "//", 
   "Transpose"}]}]], "Input",
